{
  "expo": {
    "name": "Huddle",
    "slug": "huddle",
    "scheme": "huddle",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "router": {
        "origin": "https://huddle.efren.org"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-sqlite",
      "expo-web-browser",
      "expo-font"
    ]
  }
}
